# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Security
# Generate JWT_SECRET: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_jwt_secret_here
# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# App URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# MCP tool server (optional). Leave unset to run the Gmail MCP server in-process
# (default). Set to a base URL to reach a remotely-deployed MCP server over HTTP.
# MCP_SERVER_URL=https://your-backend.example.com
